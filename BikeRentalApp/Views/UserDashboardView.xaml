<UserControl x:Class="BikeRentalApp.Views.UserDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BikeRentalApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Windows 11 style floating header -->
        <Border Background="{StaticResource SurfaceBrush}" Padding="20,15" Margin="10,10,10,0" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#20000000" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Witaj, " FontSize="20"/>
                    <TextBlock Text="{Binding User.UserName}" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Saldo: " VerticalAlignment="Center" FontSize="16" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding User.Balance, StringFormat='{}{0:N2} zł'}" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,20,0"/>
                    <Button Content="Wyloguj" Command="{Binding LogoutCommand}" Style="{StaticResource ModernButton}" Background="#FF5F5F" Padding="15,8" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10">
            <TabItem Header="Wypożycz/Zwróć">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Wybierz stację wypożyczenia" Style="{StaticResource LabelBlock}"/>
                        
                        <!-- Nowoczesne menu stacji -->
                        <ListBox ItemsSource="{Binding Stations}" SelectedItem="{Binding SelectedStation}" Background="Transparent" BorderThickness="0" Margin="0,5,0,15" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="15,10"/>
                                    <Setter Property="Margin" Value="0,0,10,10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="#F0F8FF"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StationName}" FontWeight="SemiBold" FontSize="14"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <TextBlock Text="Dostępne rowery" Style="{StaticResource LabelBlock}" Margin="0,10,0,5"/>
                        <ListBox ItemsSource="{Binding AvailableBikes}" SelectedItem="{Binding SelectedBike}" Style="{StaticResource ModernRowList}" Height="250">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Model}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PricePerHour, StringFormat='{}{0:N2} zł/h'}" Grid.Column="1" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Wypożycz wybrany rower" Command="{Binding RentCommand}" Style="{StaticResource ModernButton}" Margin="0,15,0,0"/>
                        <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="#FF5F5F" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Twoje aktualne wypożyczenie" Style="{StaticResource HeaderBlock}" FontSize="18"/>
                        <Border Background="White" Padding="25" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentRental.Bike.Model, FallbackValue='Brak aktywnego wypożyczenia'}" FontWeight="Bold" FontSize="18"/>
                                <TextBlock Text="{Binding CurrentRental.StartTime, StringFormat='Wypożyczono: {0:g}'}" Margin="0,8,0,0" Foreground="#666666" Visibility="{Binding CurrentRental, Converter={StaticResource NullToVisibilityConverter}}"/>
                                
                                <Border Background="#FFF1F0" Padding="15,10" CornerRadius="8" Margin="0,15,0,0" Visibility="{Binding CurrentRental, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ElapsedTime}" FontSize="20" FontWeight="Bold" Foreground="#F5222D" HorizontalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Wybierz stację zwrotu:" Style="{StaticResource LabelBlock}" Margin="0,20,0,5" Visibility="{Binding CurrentRental, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <ComboBox ItemsSource="{Binding Stations}" SelectedItem="{Binding ReturnStation}" DisplayMemberPath="StationName" Padding="10,8" Visibility="{Binding CurrentRental, Converter={StaticResource NullToVisibilityConverter}}"/>
                                
                                <Button Content="Zwróć rower" Command="{Binding ReturnCommand}" Style="{StaticResource ModernButton}" Background="#52C41A" Margin="0,20,0,0" Visibility="{Binding CurrentRental, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Historia">
                <StackPanel Margin="10">
                    <TextBlock Text="Historia Twoich wypożyczeń" Style="{StaticResource HeaderBlock}" FontSize="18"/>
                    <Grid Margin="15,0,15,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rower / Stacje" Grid.Column="0" FontWeight="SemiBold" Foreground="#666666"/>
                        <TextBlock Text="Start" Grid.Column="1" FontWeight="SemiBold" Foreground="#666666"/>
                        <TextBlock Text="Koniec" Grid.Column="2" FontWeight="SemiBold" Foreground="#666666"/>
                        <TextBlock Text="Koszt" Grid.Column="3" FontWeight="SemiBold" Foreground="#666666" HorizontalAlignment="Right"/>
                    </Grid>
                    <ListBox ItemsSource="{Binding RentalHistory}" Style="{StaticResource ModernRowList}" Height="450">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Bike.Model}" FontWeight="Bold"/>
                                        <TextBlock FontSize="11" Foreground="#666666">
                                            <Run Text="{Binding StartStation.StationName}"/>
                                            <Run Text=" ➔ "/>
                                            <Run Text="{Binding EndStation.StationName}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:g}'}" Grid.Column="1" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding EndTime, StringFormat='{}{0:g}'}" Grid.Column="2" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N2} zł'}" Grid.Column="3" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>

            <TabItem Header="Konto">
                <Grid>
                    <Border Background="White" CornerRadius="12" Margin="20" MaxWidth="750" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="45" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.05"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Ustawienia Twojego konta" Style="{StaticResource HeaderBlock}" FontSize="26" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Lewa strona: Doładowanie -->
                                <StackPanel Grid.Column="0">
                                    <Border Background="#F9F9F9" Padding="20" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Text="Doładuj saldo" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                            <TextBlock Text="Kwota doładowania (PLN)" Style="{StaticResource LabelBlock}"/>
                                            <TextBox Text="{Binding RechargeAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" FontSize="18"/>
                                            <Button Content="Zasil konto" Command="{Binding RechargeCommand}" Style="{StaticResource ModernButton}" Margin="0,20,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Prawa strona: Zmiana hasła -->
                                <StackPanel Grid.Column="2">
                                    <Border Background="#F9F9F9" Padding="20" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Text="Zmień hasło" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                            <TextBlock Text="Nowe hasło" Style="{StaticResource LabelBlock}"/>
                                            <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" FontSize="18"/>
                                            <Button Content="Ustaw hasło" Command="{Binding ChangePasswordCommand}" Style="{StaticResource ModernButton}" Margin="0,20,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="{Binding StatusMessage}" Margin="0,40,0,0" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>